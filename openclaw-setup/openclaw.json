{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "custom-lmstudio/qwen/qwen3.5-9b"
      },
      "thinkingDefault": "off"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "custom-lmstudio": {
        "baseUrl": "http://127.0.0.1:11435",
