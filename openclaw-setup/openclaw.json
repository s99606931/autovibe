        "models": [
          {
            "id": "qwen/qwen3.5-9b",
            "name": "qwen3.5-9b (LMStudio via smart-proxy)",
            "contextWindow": 32768,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "qwen/qwen3.6-27b",
            "name": "qwen3.6-27b (LMStudio via smart-proxy - 16K ctx 필요)",
            "contextWindow": 16384,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
          }
        ]
      }
    }
  }
}
