# ============================================================
# OpenClaw × LMStudio 환경 변수 설정
# 이 파일을 .env 로 복사한 후 값을 설정하세요.
# $ cp .env.example .env
# ============================================================

# ──────────────────────────────────────────────────────────
# [필수] LMStudio 설정
# LMStudio → 상단 메뉴 → Developer → Start Server 로 서버를 먼저 활성화하세요.
# ──────────────────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://192.168.0.104:1234
LMSTUDIO_MODEL=gemma-4-e4b-it

# OpenAI 호환 API 키 (LMStudio는 임의값 허용)
OPENAI_API_KEY=lm-studio

# ──────────────────────────────────────────────────────────
# [선택] OpenClaw 게이트웨이 인증
# 보안을 위해 아래 명령으로 토큰을 생성하세요:
# $ openssl rand -hex 32
# ──────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=

# 비밀번호 방식 인증 (토큰 대신 사용 가능)
# OPENCLAW_GATEWAY_PASSWORD=

# ──────────────────────────────────────────────────────────
# [선택] OpenClaw 경로 설정
# 기본값: ~/.openclaw
# ──────────────────────────────────────────────────────────
OPENCLAW_STATE_DIR=~/.openclaw
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# ──────────────────────────────────────────────────────────
# [선택] 메시징 채널 토큰 (사용하는 채널만 설정)
# ──────────────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Discord
# DISCORD_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ──────────────────────────────────────────────────────────
# [선택] 보조 AI 서비스 (클라우드 모델 혼합 시)
# ──────────────────────────────────────────────────────────

# Anthropic Claude (로컬+클라우드 혼합 시)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (필요 시)
# OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────
# [선택] 도구 서비스
# ──────────────────────────────────────────────────────────
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=pplx-...
# ELEVENLABS_API_KEY=
