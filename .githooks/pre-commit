#!/bin/bash
# AutoVibe Harness Engineering — Pre-Commit Quality Gate
# Gate 1: 시크릿/민감정보 유출 스캔
# Gate 2: 데드코드 잔존 검사 (TODO/FIXME/console.log)
# Gate 3: 주석 처리된 코드 블록 검사
# 우회: git commit --no-verify (긴급 시만 사용, PR에 이유 명시 필수)

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0

echo -e "${CYAN}[av-harness] Pre-Commit Quality Gate 실행 중...${NC}"

# 스테이징된 파일 목록
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}[av-harness] 스테이징된 파일 없음. 통과.${NC}"
  exit 0
fi

# ─── Gate 1: 시크릿/민감정보 스캔 ────────────────────────────────────────────
echo -e "\n${CYAN}[Gate 1] 시크릿/민감정보 스캔...${NC}"

SECRET_PATTERNS=(
  'password\s*=\s*["\047][^"\047]{4,}'
  'api[_-]?key\s*=\s*["\047][A-Za-z0-9_\-]{10,}'
  'secret\s*=\s*["\047][^"\047]{8,}'
  'token\s*=\s*["\047][A-Za-z0-9_\-\.]{20,}'
  'AKIA[0-9A-Z]{16}'
  'sk-[A-Za-z0-9]{32,}'
  'eyJ[A-Za-z0-9_\-]*\.[A-Za-z0-9_\-]*\.[A-Za-z0-9_\-]*'
  'mongodb(\+srv)?://[^@\s]+@'
  'postgres://[^@\s]+@'
  'mysql://[^@\s]+@'
)

SECRET_FOUND=0
for file in $STAGED_FILES; do
  [ -f "$file" ] || continue
  # .env 파일 자체는 허용 (gitignore로 관리됨)
  [[ "$file" == *.env* ]] && continue
  [[ "$file" == *test* ]] && continue
  [[ "$file" == *.example ]] && continue
  # 보안 도구 정의 파일 제외 (의도적으로 위험 패턴을 정의하는 화이트리스트)
  [[ "$file" == .claude/hooks/* ]] && continue
  [[ "$file" == .githooks/* ]] && continue
  [[ "$file" == .claude/rules/av-base-code-quality-gates.md ]] && continue
  # 메모리/문서 파일 제외 (실제 시크릿이 아닌 패턴 설명만 포함)
  [[ "$file" == .claude/agent-memory/* ]] && continue
  [[ "$file" == docs/* ]] && continue

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git show ":$file" 2>/dev/null | grep -iE "$pattern" > /dev/null 2>&1; then
      echo -e "${RED}  ✗ 시크릿 패턴 감지: $file (패턴: $pattern)${NC}"
      SECRET_FOUND=1
      FAIL=$((FAIL + 1))
    fi
  done
done

if [ $SECRET_FOUND -eq 0 ]; then
  echo -e "${GREEN}  ✓ 시크릿 없음${NC}"
  PASS=$((PASS + 1))
fi

# ─── Gate 2: 데드코드 잔존 검사 ──────────────────────────────────────────────
echo -e "\n${CYAN}[Gate 2] 데드코드 잔존 검사...${NC}"

DEAD_CODE_FOUND=0
DEAD_PATTERNS=(
  "console\.log("
  "console\.error("
  "console\.warn("
  "print("
  "fmt\.Println("
  "System\.out\.println("
  "debugger;"
  "binding\.pry"
)

# TODO/FIXME는 경고만
TODO_FOUND=0

for file in $STAGED_FILES; do
  [ -f "$file" ] || continue
  [[ "$file" == *.md ]] && continue
  [[ "$file" == *.json ]] && continue
  [[ "$file" == *test* ]] && continue
  [[ "$file" == *spec* ]] && continue
  [[ "$file" == *.sh ]] && continue
  # 보안/품질 가드 정의 파일 제외 (의도적으로 위험 패턴을 정의하는 화이트리스트)
  [[ "$file" == .githooks/* ]] && continue
  [[ "$file" == .claude/hooks/* ]] && continue
  [[ "$file" == .claude/rules/av-base-code-quality-gates.md ]] && continue

  for pattern in "${DEAD_PATTERNS[@]}"; do
    LINES=$(git show ":$file" 2>/dev/null | grep -n -- "$pattern" | head -3 || true)
    if [ -n "$LINES" ]; then
      echo -e "${RED}  ✗ 데드코드: $file — $pattern${NC}"
      echo -e "    $LINES"
      DEAD_CODE_FOUND=1
      FAIL=$((FAIL + 1))
    fi
  done

  # TODO/FIXME 경고
  TODO_LINES=$(git show ":$file" 2>/dev/null | grep -n -- "TODO\|FIXME\|HACK\|XXX" | head -3 || true)
  if [ -n "$TODO_LINES" ]; then
    echo -e "${YELLOW}  ⚠ TODO/FIXME 주석: $file (경고만, 이슈 트래커로 이동 권장)${NC}"
    TODO_FOUND=1
    WARN=$((WARN + 1))
  fi
done

if [ $DEAD_CODE_FOUND -eq 0 ]; then
  echo -e "${GREEN}  ✓ 데드코드 없음${NC}"
  PASS=$((PASS + 1))
fi

# ─── Gate 3: 주석 처리된 코드 블록 검사 ──────────────────────────────────────
echo -e "\n${CYAN}[Gate 3] 주석 처리된 코드 블록 검사...${NC}"

COMMENTED_FOUND=0
for file in $STAGED_FILES; do
  [ -f "$file" ] || continue
  [[ "$file" == *.md ]] && continue
  [[ "$file" == *.sh ]] && continue

  # 3줄 이상 연속 주석 처리된 코드 감지
  if git show ":$file" 2>/dev/null | \
     awk '/^[[:space:]]*(\/\/|#|--)[[:space:]]*(const|let|var|function|def |class |import |return |if |for |while )/{count++; if(count>=3){found=1; exit}} !/^[[:space:]]*(\/\/|#|--)[[:space:]]*(const|let|var|function|def |class |import |return |if |for |while )/{count=0} END{exit !found}' 2>/dev/null; then
    echo -e "${YELLOW}  ⚠ 주석 처리된 코드 블록 감지: $file (삭제 권장, git history로 복구 가능)${NC}"
    COMMENTED_FOUND=1
    WARN=$((WARN + 1))
  fi
done

if [ $COMMENTED_FOUND -eq 0 ]; then
  echo -e "${GREEN}  ✓ 주석 처리된 코드 없음${NC}"
  PASS=$((PASS + 1))
fi

# ─── Gate 4: 파일 크기 검사 ──────────────────────────────────────────────────
echo -e "\n${CYAN}[Gate 4] 파일 크기 검사 (500줄 제한)...${NC}"

SIZE_FAIL=0
for file in $STAGED_FILES; do
  [ -f "$file" ] || continue
  [[ "$file" == *.md ]] && continue
  [[ "$file" == *.json ]] && continue
  [[ "$file" == *.lock ]] && continue
  [[ "$file" == *.svg ]] && continue

  LINE_COUNT=$(git show ":$file" 2>/dev/null | wc -l || echo 0)
  if [ "$LINE_COUNT" -gt 500 ]; then
    echo -e "${YELLOW}  ⚠ 파일 크기 초과: $file (${LINE_COUNT}줄 > 500줄 권장, 분리 검토)${NC}"
    SIZE_FAIL=1
    WARN=$((WARN + 1))
  fi
done

if [ $SIZE_FAIL -eq 0 ]; then
  echo -e "${GREEN}  ✓ 파일 크기 정상${NC}"
  PASS=$((PASS + 1))
fi

# ─── 결과 요약 ────────────────────────────────────────────────────────────────
echo -e "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "[av-harness] Pre-Commit 결과: ${GREEN}PASS ${PASS}${NC} | ${YELLOW}WARN ${WARN}${NC} | ${RED}FAIL ${FAIL}${NC}"
echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $FAIL -gt 0 ]; then
  echo -e "${RED}[av-harness] ✗ 커밋 차단됨. 위 오류를 수정 후 다시 커밋하세요.${NC}"
  echo -e "${YELLOW}  긴급 우회: git commit --no-verify (PR에 이유 명시 필수)${NC}"
  exit 1
fi

if [ $WARN -gt 0 ]; then
  echo -e "${YELLOW}[av-harness] ⚠ 경고 ${WARN}개. 권장 수정 후 커밋하세요. (커밋은 허용됨)${NC}"
fi

echo -e "${GREEN}[av-harness] ✓ Pre-Commit 통과.${NC}"
exit 0
