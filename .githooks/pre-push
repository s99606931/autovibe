#!/bin/bash
# AutoVibe Harness Engineering — Pre-Push Quality Gate
# Gate 5: TypeScript 타입 검사 (tsconfig.json 존재 시)
# Gate 6: 테스트 실행 (package.json test script 존재 시)
# Gate 7: main/master 직접 push 차단
# 우회: git push --no-verify (긴급 시만 사용)

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

PASS=0
FAIL=0

echo -e "${CYAN}[av-harness] Pre-Push Quality Gate 실행 중...${NC}"

# push 대상 브랜치 확인
while read local_ref local_sha remote_ref remote_sha; do
  BRANCH=$(echo "$remote_ref" | sed 's|refs/heads/||')

  # ─── Gate 7: main/master 직접 push 차단 ────────────────────────────────────
  echo -e "\n${CYAN}[Gate 7] 보호 브랜치 직접 push 검사...${NC}"
  if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
    echo -e "${RED}  ✗ main/master 브랜치에 직접 push는 금지됩니다.${NC}"
    echo -e "    PR을 통해 merge하세요: git checkout -b feature/xxx && git push origin feature/xxx"
    echo -e "${YELLOW}    긴급 배포 시: git push --no-verify (리드 승인 필수)${NC}"
    exit 1
  fi
  echo -e "${GREEN}  ✓ 보호 브랜치 아님 ($BRANCH)${NC}"
  PASS=$((PASS + 1))
done

# 현재 디렉토리 기준 프로젝트 타입 감지
ROOT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# ─── Gate 5: TypeScript 타입 검사 ─────────────────────────────────────────────
echo -e "\n${CYAN}[Gate 5] TypeScript 타입 검사...${NC}"

if [ -f "$ROOT_DIR/tsconfig.json" ] && command -v npx &> /dev/null; then
  if [ -f "$ROOT_DIR/package.json" ]; then
    cd "$ROOT_DIR"
    echo -e "  TypeScript 프로젝트 감지. 타입 검사 실행 중..."
    if npx tsc --noEmit 2>&1 | tail -20; then
      echo -e "${GREEN}  ✓ TypeScript 타입 검사 통과${NC}"
      PASS=$((PASS + 1))
    else
      echo -e "${RED}  ✗ TypeScript 타입 오류 발생. 수정 후 push하세요.${NC}"
      FAIL=$((FAIL + 1))
    fi
  fi
else
  echo -e "${YELLOW}  - TypeScript 프로젝트 아님 또는 npx 없음. 건너뜀.${NC}"
fi

# ─── Gate 6: 테스트 실행 ──────────────────────────────────────────────────────
echo -e "\n${CYAN}[Gate 6] 테스트 실행...${NC}"

if [ -f "$ROOT_DIR/package.json" ]; then
  if grep -q '"test"' "$ROOT_DIR/package.json" 2>/dev/null; then
    cd "$ROOT_DIR"
    echo -e "  npm test 실행 중..."
    if npm test -- --passWithNoTests --watchAll=false 2>&1 | tail -20; then
      echo -e "${GREEN}  ✓ 테스트 통과${NC}"
      PASS=$((PASS + 1))
    else
      echo -e "${RED}  ✗ 테스트 실패. 수정 후 push하세요.${NC}"
      FAIL=$((FAIL + 1))
    fi
  else
    echo -e "${YELLOW}  - package.json에 test 스크립트 없음. 건너뜀.${NC}"
  fi
elif [ -f "$ROOT_DIR/go.mod" ] && command -v go &> /dev/null; then
  cd "$ROOT_DIR"
  echo -e "  go test 실행 중..."
  if go test ./... 2>&1 | tail -10; then
    echo -e "${GREEN}  ✓ Go 테스트 통과${NC}"
    PASS=$((PASS + 1))
  else
    echo -e "${RED}  ✗ Go 테스트 실패.${NC}"
    FAIL=$((FAIL + 1))
  fi
elif [ -f "$ROOT_DIR/requirements.txt" ] || [ -f "$ROOT_DIR/pyproject.toml" ]; then
  if command -v pytest &> /dev/null; then
    cd "$ROOT_DIR"
    echo -e "  pytest 실행 중..."
    if pytest --tb=short -q 2>&1 | tail -10; then
      echo -e "${GREEN}  ✓ Python 테스트 통과${NC}"
      PASS=$((PASS + 1))
    else
      echo -e "${RED}  ✗ Python 테스트 실패.${NC}"
      FAIL=$((FAIL + 1))
    fi
  else
    echo -e "${YELLOW}  - pytest 없음. 건너뜀.${NC}"
  fi
else
  echo -e "${YELLOW}  - 테스트 환경 없음. 건너뜀.${NC}"
fi

# ─── 결과 요약 ────────────────────────────────────────────────────────────────
echo -e "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "[av-harness] Pre-Push 결과: ${GREEN}PASS ${PASS}${NC} | ${RED}FAIL ${FAIL}${NC}"
echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $FAIL -gt 0 ]; then
  echo -e "${RED}[av-harness] ✗ Push 차단됨. 위 오류를 수정 후 다시 push하세요.${NC}"
  echo -e "${YELLOW}  긴급 우회: git push --no-verify (리드 승인 필수)${NC}"
  exit 1
fi

echo -e "${GREEN}[av-harness] ✓ Pre-Push 통과.${NC}"
exit 0
